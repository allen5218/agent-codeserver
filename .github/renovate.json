{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Asia/Taipei",
  "pinDigests": true,
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true,
      "automergeStrategy": "squash"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["codercom/code-server"],
      "groupName": "code-server base image",
      "automerge": false
    }
  ]
}
