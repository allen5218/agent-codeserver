# ---- code-server ----
# code-server 登入密碼（compose 會映射成容器內的 PASSWORD）
CODE_PASSWORD=change-me

# ---- 容器執行身分 ----
# 容器以這個 UID:GID 執行，必須與主機上 /opt/docker-stacks/vscode 的擁有者一致。
# 用 `id -u` / `id -g` 查你要使用的值。
APP_UID=1000
APP_GID=1000

# ---- Cloudflare Tunnel ----
# Zero Trust → Networks → Tunnels 建立 tunnel 後複製的 token。
CF_TUNNEL_TOKEN=your-cloudflare-tunnel-token
